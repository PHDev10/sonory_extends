<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ifpb.sonoryextends.controller.PlaybackController"
            prefWidth="1000"
            prefHeight="700"
            styleClass="root-pane">

    <top>
        <VBox alignment="CENTER" spacing="12" styleClass="header-box">
            <Label text="Sonory Extends - Reprodutor"
                   styleClass="title-label"/>

            <HBox spacing="15" alignment="CENTER">
                <Button text="← Voltar"
                        styleClass="secondary-button"
                        onAction="#voltarParaConversao"/>

                <Button text="Abrir Pasta do Backup"
                        styleClass="action-button"
                        onAction="#abrirPastaBackup"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="center-box">
            <VBox spacing="25"
                  alignment="CENTER"
                  styleClass="player-card">

                <Label text="Arquivos Convertidos"
                       styleClass="subtitle-label"/>

                <ListView fx:id="listaDeVisualizacaoArquivos"
                          prefWidth="550"
                          prefHeight="250"
                          styleClass="audio-list"/>

                <HBox spacing="25" alignment="CENTER">

                    <Button text="▶"
                            prefWidth="80"
                            prefHeight="60"
                            styleClass="play-button"
                            onAction="#handlePlay"/>

                    <Button text="⏸"
                            prefWidth="80"
                            prefHeight="60"
                            styleClass="pause-button"
                            onAction="#handlePause"/>

                </HBox>

                <VBox spacing="8" alignment="CENTER">
                    <Label text="Volume"
                           style="-fx-font-weight: 600;"/>

                    <Slider fx:id="volumeSlider"
                            prefWidth="400"
                            min="0"
                            max="100"
                            value="50"
                            styleClass="volume-slider"/>
                </VBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>